{
  "name": "astro-aeo-image",
  "version": "0.2.1",
  "description": "Astro image service that embeds your <Image> alt text (and optional description/keywords) as standards XMP into the optimized output files — so your dist/_astro assets are self-describing for Google Images and AI answer engines. Wraps Astro's default sharp service; byte-preserving metadata layer via aeo-image.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./service": {
      "types": "./dist/service.d.ts",
      "default": "./dist/service.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "src"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=20.19.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vsima/astro-aeo-image.git"
  },
  "homepage": "https://github.com/vsima/astro-aeo-image#readme",
  "bugs": {
    "url": "https://github.com/vsima/astro-aeo-image/issues"
  },
  "scripts": {
    "test": "node --test test/*.test.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "astro",
    "astro-integration",
    "astro-image-service",
    "withastro",
    "aeo",
    "seo",
    "xmp",
    "alt-text",
    "image-metadata",
    "accessibility",
    "answer-engine-optimization"
  ],
  "license": "MIT",
  "dependencies": {
    "aeo-image": "^1.0.1"
  },
  "peerDependencies": {
    "astro": ">=4.0.0"
  },
  "devDependencies": {
    "astro": "^6.4.2",
    "typescript": "^6.0.3"
  }
}
